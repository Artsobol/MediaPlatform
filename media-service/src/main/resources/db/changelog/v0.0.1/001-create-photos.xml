<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260530_create_photo_id_seq" author="artsobol">
        <createSequence sequenceName="photo_id_seq" startValue="1" incrementBy="50"/>
    </changeSet>

    <changeSet id="20260530_create_photos_table" author="artsobol">
        <createTable tableName="photos">
            <column name="id" type="bigint" defaultValueSequenceNext="photo_id_seq">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_photos"/>
            </column>
            <column name="title" type="varchar(100)">
            </column>
            <column name="description" type="varchar(1000)">
            </column>
            <column name="original_image_key" type="varchar(255)">
                <constraints unique="true" uniqueConstraintName="uq_photos_original_image_key"/>
            </column>
            <column name="photo_date" type="date">
            </column>
            <column name="photo_status" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamptz" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamptz" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
</databaseChangeLog>
